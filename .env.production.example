# Copy this to .env on the server and fill in your values
# Never commit .env to git

# PostgreSQL
POSTGRES_DB=examapp
POSTGRES_USER=examuser
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_HERE

# Backend
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_HERE
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD_HERE
