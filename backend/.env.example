# CertPath — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# NOTE: When running via docker compose, environment variables are injected
# directly from docker-compose.yml — this file is only needed when running
# the backend outside of Docker (e.g. native Node.js on EC2).

NODE_ENV=development
PORT=3001

# PostgreSQL connection string
# Local Docker:  postgresql://examuser:exampass@localhost:5432/examapp
# Supabase:      postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# JWT signing secret (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Admin account — created automatically on first migration run
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Superuser account — created automatically on first migration run
SUPER_EMAIL=
SUPER_PASSWORD=
